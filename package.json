{
  "name": "paperclip-plugin-claude-token-usage",
  "version": "0.4.0",
  "description": "Track Claude token usage per Paperclip company, store daily rollups, render a dashboard, and export a weekly CSV for token-based billing. Pricing table covers Opus 4.8 / 4.7 and Sonnet 4.6 / 4.5 with 1M-context variants.",
  "private": true,
  "type": "module",
  "main": "dist/worker.js",
  "files": [
    "dist",
    "migrations",
    "README.md"
  ],
  "paperclipPlugin": {
    "manifest": "dist/manifest.js",
    "worker": "dist/worker.js",
    "ui": "dist/ui",
    "migrationsDir": "migrations"
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "@paperclipai/plugin-sdk": "*"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@paperclipai/plugin-sdk": "*",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/node": "^22.9.0",
    "esbuild": "^0.24.0",
    "rollup": "^4.24.0",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-commonjs": "^28.0.1",
    "@rollup/plugin-typescript": "^12.1.1",
    "tslib": "^2.8.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "paperclip",
    "paperclip-plugin",
    "tokens",
    "usage",
    "usage-costs",
    "billing",
    "pricing",
    "claude"
  ],
  "license": "UNLICENSED"
}
